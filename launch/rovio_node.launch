<?xml version="1.0" encoding="UTF-8"?> 
<launch>
  <param name="/use_sim_time" value="true" />
  <node pkg="rovio" type="rovio_node" name="rovio" output="screen">
  <param name="filter_config" value="$(find rovio)/cfg/rovio.info"/>
  <param name="camera0_config" value="$(find rovio)/cfg/euroc_cam0.yaml"/>
    <remap from="cam0/image_raw" to="/cam0/image_raw"/>
    <remap from="imu0" to="/imu"/>
<!--  <param name="camera1_config" value="$(find rovio)/cfg/euroc_cam1.yaml"/>-->
<!--    <param name="image_mask_path" value="/test/test/tes" />-->
    <param name="filter_config" value="$(find rovio)/cfg/rovio_omav4.info"/>
    <param name="camera0_config" value="$(find rovio)/cfg/rovio_omav4.yaml"/>
    <param name="image_mask_path" value="/home/christian/begs/fusilib/tuning/mask.png" />
    <param name="world_frame" value="world"/>
    <param name="imu_frame" value="imu_rovio"/>
    <remap from="cam0/image_raw" to="/cam0/image_raw"/>
    <remap from="imu0" to="/imu"/>
  </node>



</launch>
