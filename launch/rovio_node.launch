<?xml version="1.0" encoding="UTF-8"?> 
<launch>
  <node pkg="rovio" type="rovio_node" name="rovio" output="screen">
  <param name="filter_config" value="$(find rovio)/cfg/rovio.info"/>
  <param name="camera0_config" value="$(find rovio)/cfg/euroc_cam0.yaml"/>
    <remap from="cam0/image_raw" to="/quail/cam0/image_raw"/>
    <remap from="imu0" to="/quail/imu/data_raw"/>
<!--  <param name="camera1_config" value="$(find rovio)/cfg/euroc_cam1.yaml"/>-->
<!--    <param name="image_mask_path" value="/test/test/tes" />-->
  </node>
</launch>
